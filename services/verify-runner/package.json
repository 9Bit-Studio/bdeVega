{
  "name": "verify-runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsup src/server.ts --format esm --sourcemap --clean --external playwright",
    "dev": "node --env-file=../../.env.local --watch --import tsx src/server.ts",
    "lint": "tsc --noEmit",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vega/spec": "workspace:*",
    "express": "^5.1.0",
    "playwright": "^1.55.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.10",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsup": "8.5.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}

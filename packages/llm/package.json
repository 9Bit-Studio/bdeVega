{
  "name": "@vega/llm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./src/node.ts",
      "import": "./dist/node.js"
    }
  },
  "files": ["dist", "fixtures"],
  "scripts": {
    "build": "tsup src/index.ts src/node.ts --format esm --dts --sourcemap --clean --external openai --external @anthropic-ai/sdk --external @google/genai",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.111.0",
    "@google/genai": "2.11.0",
    "openai": "6.46.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "tsup": "8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}

# Browser-visible URL for the anonymous local Convex backend.
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Local platform URL used when Convex asks the verify-runner to load a game.
APP_URL=http://127.0.0.1:3000

# Local Playwright verification service.
VERIFY_RUNNER_URL=http://127.0.0.1:4001
# Shared only by Convex and the verifier. Use a fresh 32+ character secret in every environment.
VERIFY_RUNNER_TOKEN=replace-with-a-separate-long-random-service-token
# Exact comma-separated origins the verifier may navigate to.
VERIFY_ALLOWED_APP_ORIGINS=http://127.0.0.1:3000
# Local-only exception. Production must leave this false.
VERIFY_ALLOW_PRIVATE_ADDRESSES=true
VERIFY_MAX_CONCURRENT=2
VERIFY_RATE_LIMIT_PER_MINUTE=30

# At least 32 random characters; used only inside Convex actions for AES-256-GCM.
API_KEY_ENCRYPTION_SECRET=replace-with-a-long-random-local-secret

# Bring-your-own provider keys. Leave unused providers blank.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Force every generation stage onto the provider's cheapest supported model.
DEV_MODEL_TIER=cheap

# Offline/cost-free defaults. Set LLM_REPLAY=false and LLM_RECORD=true once to record fixtures.
LLM_REPLAY=true
LLM_RECORD=false

# Exercise publish UI and payload construction without contacting Vercel.
PUBLISH_DRY_RUN=true
VERCEL_TOKEN=
# Optional but recommended: the platform's Vercel team ID. This keeps every
# generated game project under the shared Vega account instead of a token's
# default personal scope.
VERCEL_TEAM_ID=

# Local seeded account.
TEST_USER_EMAIL=developer@localhost
TEST_USER_NAME=Local Developer
